/dist/

# Frontend toolchain (the built bundle is committed; its deps are not)
node_modules/
pycanvas/frontend/.vite/

# Generated example output (created by running the save/load + upload examples)
examples/saved_canvas.json
examples/saved_layout.json
examples/uploads/

# Live state written by the hackathon example (catalogue, teams, orders,
# announcement board) — runtime data, not source.
examples/hackathon_inventory.csv
examples/hackathon_teams.csv
examples/hackathon_orders.csv
examples/hackathon_announcement.md

