/dist/

# Frontend toolchain (the built bundle is committed; its deps are not)
node_modules/
pycanvas/frontend/.vite/

# Generated example output (created by running the save/load examples)
examples/saved_canvas.json
examples/saved_layout.json

# Editor / OS / local agent state
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db
